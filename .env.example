# MentorBoxAI Environment Variables
# Copy this file to .env and fill in actual values

# ===================
# Groq LLM API Keys (REQUIRED)
# Keys are tried in order — first valid key is used automatically
# ===================
GROQ_API_KEY1=your_groq_api_key_1_here
GROQ_API_KEY2=your_groq_api_key_2_here
GROQ_API_KEY3=your_groq_api_key_3_here
GROQ_MODEL=llama-3.3-70b-versatile

# ===================
# LLM Settings
# ===================
LLM_GENERATOR_MAX_TOKENS=4096
LLM_GENERATOR_TEMPERATURE=0.01

# ===================
# AWS (S3, DynamoDB, Lambda — NOT Bedrock)
# ===================
AWS_REGION=ap-south-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key
S3_BUCKET=mentorbocai-videos

# ===================
# API Server
# ===================
PORT=8000
NODE_ENV=production
CORS_ORIGIN=https://yourdomain.com
